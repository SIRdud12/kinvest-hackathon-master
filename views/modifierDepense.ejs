<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kinvest - Gestion Intelligente des Dépenses Personnelles</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css" integrity="sha384-TX8t27EcRE3e/ihU7zmQxVncDAy5uIKz4rEkgIXeMed4M0jlfIDPvg6uqKI2xXr2" crossorigin="anonymous">  
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <script src="/js/main.js" defer></script>
</head>
<body>
    <nav class="navbar">
        <div class="logo-container">
          <div class="logo">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 5V19M5 12H19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="brand-name">Kinvest</div>
        </div>
      
        <div class="nav-links">
            <a href="/annee/<%= (annee-2) %>"><</a>            
            <a href="/annee/<%= (annee-1) %>"><%= (annee-1) %></a>
            <b><%= annee %></b>
            <a href="/annee/<%= (parseInt(annee)+1) %>"><%= (parseInt(annee)+1) %></a>
            <a href="/annee/<%= (parseInt(annee)+2) %>">></a>
        </div>
      
        <a href="/login">
            <span><% if (user) { %><%= user.email %><% } else { %>non connecté<% } %></span>
            <a href="/logout">
                <button class="try-now-btn">Se Déconnecter</button>
            </a>
        </a>
    </nav>

    <section class="hero" id="hero">

        <h2>Modification d'une dépense</h2>
        <form action="/modifierDepense" name="form_modifier_depense" class="validated-form" method="POST" novalidate>
            <input type="hidden" name="depense" value="<%= depense[0].id %>">
            <div class="mb-3">
                <label class="form-lable" for="date">Date</label>
                <input class = "form-control" type="text" name="date" id="date" required value="<%= depense[0].date.toLocaleDateString("fr-FR") %>">
            </div>
            <div class="mb-3">
                <label class="form-lable" for="categorie">Catégorie</label>
                <select class = "form-control" name="categorie" id="categorie" required>
                    <option value="0">catégorie</option>
                    <% for( let index = 0; index < categories.length; index++ ) { %>
                        <option <% if (depense[0].categorie_id == categories[index].id) { %>selected = "selected"<% } %> value="<%= categories[index].id %>"><%= categories[index].nom %></option>
                    <% } %>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-lable" for="montant">Montant</label>
                <input class = "form-control" type="text" name="montant" id="montant" required value="<%= depense[0].montant %>">
            </div>
            <button type="submit" class="budget-btn">Modifier</button>
        </form>
    </section>
  
</body>
</html>
